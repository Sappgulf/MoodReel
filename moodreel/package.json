{
  "name": "moodreel",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "dependencies": {
    "axios": "^1.10.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.6.2"
  },
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "browsers:ensure": "npx playwright install chromium webkit",
    "build": "vite build && node scripts/inject-sw-version.cjs",
    "analyze": "ANALYZE=1 vite build && node scripts/inject-sw-version.cjs",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:unit": "vitest run",
    "test:ci": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke": "node scripts/smoke.js",
    "bundle:check": "node scripts/check-bundle-size.cjs",
    "verify": "npm run lint && npm run test:run && npm run build && npm run bundle:check",
    "verify:full": "npm run verify && npm run test:e2e",
    "lint": "eslint src --max-warnings 0",
    "screenshots:polish": "node scripts/capture-polish-screenshots.js",
    "typecheck": "tsc --noEmit",
    "prepare": "cd .. && node moodreel/node_modules/husky/bin.js || true",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,css,md,json}": "prettier --write"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/react": "^14.2.2",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.24.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "^5.8.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.5"
  }
}
