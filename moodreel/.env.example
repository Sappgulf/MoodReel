VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TMDB_BASE_URL=https://api.themoviedb.org/3
# Set TMDB_API_KEY on Vercel to enable the server-side proxy.
# The proxy is used automatically in production to keep the API key off the client.
# For local development, set VITE_TMDB_API_KEY to your personal key.
#
# Push (Web Push / VAPID public key — safe to expose in the client bundle)
# VITE_VAPID_PUBLIC_KEY=
